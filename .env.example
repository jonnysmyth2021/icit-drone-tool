NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Legacy Supabase projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.

# Server-only integrations used by App Router route handlers.
OPENAI_API_KEY=sk-your-key
# Optional. Defaults to gpt-5.4-mini when omitted.
OPENAI_INTELLIGENCE_MODEL=gpt-5.4-mini
OPENSKY_CLIENT_ID=your-api-client-id
OPENSKY_CLIENT_SECRET=your-api-client-secret
# Optional provider request timeouts (milliseconds).
OPENSKY_TIMEOUT_MS=8000
AIRPLANES_LIVE_TIMEOUT_MS=8000
OPENWEATHER_API_KEY=your-openweather-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Reserved for the currently unused Drizzle/Postgres module.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@your-pooler:6543/postgres
